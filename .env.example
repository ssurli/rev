# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Revolut Open Banking
REVOLUT_CLIENT_ID=
REVOLUT_CLIENT_SECRET=
REVOLUT_SANDBOX=true

# NewsAPI (https://newsapi.org — free tier: 100 req/day)
NEWSAPI_KEY=

# FRED API — Federal Reserve Economic Data (free key: fred.stlouisfed.org/docs/api/api_key.html)
# Fornisce: Fed Funds Rate, CPI, Unemployment, Treasury Yields, VIX, Consumer Sentiment
FRED_API_KEY=

# Trading mode: paper | live
TRADING_MODE=paper

# Risk / sizing (mirror revolut_invest_v3.html rules)
MAX_TRADE_EUR=50
MIN_PORTFOLIO_EUR=20
MAX_POSITION_PCT=20
MIN_CASH_PCT=15
STOP_LOSS_PCT=-15
TAKE_PROFIT_PCT=30
MAX_CRYPTO_PCT=15

# Assets to monitor (comma-separated yfinance tickers)
# Default comprende crypto, ETF, commodities e stock principali
ASSETS=BTC-USD,ETH-USD,SOL-USD,VOO,QQQ,TLT,GLD,SLV,CL=F,AAPL,MSFT,NVDA,TSLA,AMZN,META,JPM,BAC

# Cycle interval in minutes
CYCLE_INTERVAL_MINUTES=30

# Paths
DB_PATH=./data/bot.sqlite
LOG_LEVEL=INFO
